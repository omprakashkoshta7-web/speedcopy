# API Configuration
# Production Gateway URL
VITE_API_URL=https://your-gateway-url.run.app

# App Configuration
VITE_APP_NAME=SpeedCopy
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true

# Razorpay Configuration
VITE_RAZORPAY_KEY_ID=your_razorpay_key_here

# Twilio Configuration (Phone OTP)
VITE_TWILIO_VERIFY_SERVICE_SID=your_twilio_service_sid_here
