# SpeedCopy Client Environment Configuration
# Production URLs for Google Cloud Run Services

# Primary API Configuration
VITE_API_BASE_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_ENVIRONMENT=production

# Service URLs
VITE_GATEWAY_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_AUTH_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_PRODUCT_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_ADMIN_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_FINANCE_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_DESIGN_URL=https://gateway-yvakohiopa-de.a.run.app
VITE_NOTIFICATION_URL=https://gateway-yvakohiopa-de.a.run.app

# Service Status (based on testing)
# WORKING: Product, Auth
# ISSUES: Gateway, Admin
# UNKNOWN: Finance, Design, Notification

# API Configuration
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_CACHING=true
VITE_ENABLE_FALLBACK=true

# Debug Settings
VITE_DEBUG_API=true
VITE_LOG_LEVEL=info

# Firebase Configuration (if needed)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id

# Payment Configuration
VITE_RAZORPAY_KEY_ID=rzp_test_6vdMK3ln1NsDMj

# App Configuration
VITE_APP_NAME=SpeedCopy
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Fast and reliable printing, gifting, and shopping platform